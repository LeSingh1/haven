# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — NEVER commit real keys.

# REQUIRED for the Claude-powered parsing (search + tour navigation).
# Get a key at https://console.anthropic.com/  (server-side only — do NOT prefix with NEXT_PUBLIC_).
# Without it, the app still works via the keyword fallback parser.
ANTHROPIC_API_KEY=

# OPTIONAL — HUD Fair Market Rent API token (free) for an "within fair market rent" badge.
# Register at https://www.huduser.gov/portal/dataset/fmr-api.html
# HUD_API_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# REALTOR BOOKING — AI voice agent that calls the realtor to book a viewing.
# All server-side only — NEVER prefix with NEXT_PUBLIC_.
# ─────────────────────────────────────────────────────────────────────────────

# ── Credentials you have now ──
# Twilio (console.twilio.com → Account Info)
TWILIO_SID=                 # Twilio Account SID — your "SID" (starts with AC)
TWILIO_CLIENT_SECRET=       # Twilio Auth Token — your "client secret"

# ElevenLabs (elevenlabs.io → profile → API Keys)
ELEVENLABS_SID=             # your ElevenLabs "SID"
ELEVENLABS_CLIENT_SECRET=   # your ElevenLabs "client secret" (the API key the call uses)

# ── Fill in during Phase 2 (the live call) — leave blank for now ──
ELEVENLABS_AGENT_ID=        # Conversational AI → your agent → Agent ID
ELEVENLABS_PHONE_NUMBER_ID= # Twilio number imported into ElevenLabs → its ID
TWILIO_PHONE_NUMBER=        # your Twilio number, E.164 e.g. +14155551234
DEMO_REALTOR_PHONE=         # your phone (the "realtor" you answer on stage), E.164

# ── Voice-booking buyer identity (CLIENT-SIDE, non-secret; safe to expose) ──
# Used when you book a viewing hands-free by voice in the tour. Optional —
# defaults to "Haven guest" / a placeholder number if left blank.
NEXT_PUBLIC_DEMO_BUYER_NAME=
NEXT_PUBLIC_DEMO_BUYER_PHONE=
